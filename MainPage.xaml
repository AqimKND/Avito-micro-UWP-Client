<Page
    x:Class="AvitoMicro.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AvitoMicro"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <DataTemplate x:Key="ListTemplate">
            <Grid Margin="0,10" Width="380">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="#22FFFFFF">
                    <Image Source="{Binding image}" Width="90" Height="90" Stretch="UniformToFill"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock Text="{Binding title}" FontSize="20" FontWeight="Light" MaxLines="2" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding price}" FontSize="18" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" FontWeight="Normal"/>
                </StackPanel>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="GridTemplate">
            <StackPanel Width="115" Margin="2" HorizontalAlignment="Center">
                <Border Background="#22FFFFFF">
                    <Image Source="{Binding image}" Width="115" Height="90" Stretch="UniformToFill"/>
                </Border>
                <TextBlock Text="{Binding price}" FontSize="14" FontWeight="Normal" Margin="2,3,2,0" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding title}" FontSize="11" Opacity="0.7" MaxLines="2" TextWrapping="Wrap" Height="30" LineHeight="13" Margin="2,0"/>
            </StackPanel>
        </DataTemplate>
        <Style x:Key="CompactGridViewItemStyle" TargetType="GridViewItem">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinWidth" Value="115"/>
            <Setter Property="MinHeight" Value="130"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
        </Style>
    </Page.Resources>
    <Grid>
        <Image Source="Assets/PanoramaBackground.jpg" Stretch="UniformToFill" HorizontalAlignment="Left" Opacity="0.5"/>
        <Pivot x:Name="RootPivot">
            <Pivot.Title>
                <StackPanel Orientation="Horizontal">
                    <Image Source="Assets/Square44x44Logo.scale-200.png" Width="24" Height="24" Margin="0,0,10,0"/>
                    <TextBlock Text="AvitoMicro" FontSize="18" FontWeight="SemiLight"/>
                </StackPanel>
            </Pivot.Title>
            <PivotItem Header="объявления">
                <Grid Margin="10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="StatusText" Text="Обновление" FontSize="14" Opacity="0.6" Margin="0,0,0,10"/>
                    <GridView x:Name="ResultsListView" 
                              Grid.Row="1" 
                              SelectionMode="None"
                              ItemContainerStyle="{StaticResource CompactGridViewItemStyle}">
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal" HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                    </GridView>
                </Grid>
            </PivotItem>
        </Pivot>
        <WebView x:Name="AvitoBrowser" Height="1" Width="1" Visibility="Collapsed" NavigationCompleted="AvitoBrowser_NavigationCompleted"/>
    </Grid>
    <Page.BottomAppBar>
        <CommandBar x:Name="MainCommandBar" ClosedDisplayMode="Minimal">
            <AppBarButton Icon="Refresh" Label="обновить" Click="Refresh_Click"/>
            <CommandBar.SecondaryCommands>
                <AppBarButton Label="настройки" Click="Secondary_Click"/>
                <AppBarButton Label="о программе" Click="About_Click"/>
            </CommandBar.SecondaryCommands>
        </CommandBar>
    </Page.BottomAppBar>
</Page>