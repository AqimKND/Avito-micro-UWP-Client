<Page
    x:Class="AvitoMicro.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AvitoMicro"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Background="White">
        <ScrollViewer>
            <StackPanel Margin="20,40,20,100">
                <TextBlock Text="О ПРОГРАММЕ" FontSize="18" Foreground="Gray" Margin="0,0,0,40"/>

                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,30">
                    <Image Source="Assets/SplashScreen.scale-200.png" Width="180" Stretch="Uniform"/>
                </StackPanel>

                <TextBlock Text="Версия: 0.1.1.0" Foreground="Gray" Margin="0,0,0,20"/>

                <TextBlock Text="Объявления частных лиц и компаний о продаже товаров и услуг." 
                           TextWrapping="Wrap" Foreground="DimGray" FontSize="18" Margin="0,0,0,10"/>
                <TextBlock Text="Автомобили, недвижимость, одежда, электроника, техника, мебель, работа, животные и многое другое." 
                           TextWrapping="Wrap" Foreground="DimGray" FontSize="18"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,150,0,0">
                    <TextBlock Text="Developed by: KND, 𝙇 𝙔 𝙉 𝙓, LegacyProjects" Foreground="Gray" Margin="0,-90,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20">
            <Button Click="Back_Click" Width="50" Height="50" Padding="0" Background="Transparent" BorderBrush="Gray" BorderThickness="1">
                <Image Source="Assets/Back.png" Width="24" Height="24" Opacity="0.6"/>
            </Button>
        </StackPanel>
    </Grid>
</Page>