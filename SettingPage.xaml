<Page
    x:Class="AvitoMicro.SettingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <!-- Твоя панорамная подложка -->
        <Image Source="Assets/PanoramaBackground.jpg" Stretch="UniformToFill" Opacity="0.5"/>

        <ScrollViewer>
            <StackPanel Margin="24,60,24,40">

                <!-- ЗАГОЛОВОК -->
                <Grid Margin="0,0,0,40">
                    <TextBlock Text="НАСТРОЙКИ" FontSize="18" FontWeight="Bold" CharacterSpacing="100"/>
                </Grid>

                <TextBlock Text="Стиль ленты" FontSize="26" FontWeight="Light" Margin="0,0,0,15"/>
                <RadioButton x:Name="StyleList" Content="Линейный (Ближе к старой версии)" GroupName="StyleGroup" Margin="0,5"/>
                <RadioButton x:Name="StyleGrid" Content="Плиточный (ближе к новой версии)" GroupName="StyleGroup" Margin="0,5"/>

                <Grid Margin="0,30,0,10">
                    <TextBlock Text="Выбор способа загрузки" FontSize="26" FontWeight="Light" VerticalAlignment="Center"/>
                </Grid>
                <TextBlock Text="Ключи важны для загрузки данных. Возможно, прямо сейчас один из них мёртв." FontSize="13" Opacity="0.6" TextWrapping="Wrap" Margin="0,0,0,15"/>

                <!-- Оставшиеся рабочие способы (Пустой полностью вырезан) -->
                <RadioButton x:Name="KeyParse" Content="Способ №1 (Parse key)" GroupName="KeyGroup" Margin="0,5"/>
                <RadioButton x:Name="KeyZagolovki" Content="Способ №2 (Заголовки)" GroupName="KeyGroup" Margin="0,5"/>

                <Grid Margin="0,50,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="Применить" Click="Back_Click" Grid.Column="0" HorizontalAlignment="Stretch" Height="50" Margin="0,0,5,0"/>
                    <Button x:Name="UpdateBtn" Content="Обновить" Click="CheckUpdates_Click" Grid.Column="1" HorizontalAlignment="Stretch" Height="50" Margin="5,0,0,0" BorderThickness="1"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Grid x:Name="UpdateOverlay" Visibility="Collapsed" Background="#CC000000">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Background="White" Padding="30" Width="360">
                <TextBlock Text="Обновление" Foreground="Black" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                <TextBlock x:Name="UpdateVersionTextOverlay" Text="Версия: 0.0.0.0" Foreground="#444444" FontSize="20" Margin="0,0,0,25"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <StackPanel Margin="10" Tapped="CloseOverlay_Click"/>
                    <StackPanel Margin="10" Opacity="0.4"/>
                </StackPanel>
                <Button Content="ОТМЕНА" Click="CloseOverlay_Click" HorizontalAlignment="Stretch" Margin="0,25,0,0" Height="45" Foreground="Black"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
